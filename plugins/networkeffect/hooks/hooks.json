{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "test -d \"${CLAUDE_PLUGIN_ROOT}/node_modules\" || (cd \"${CLAUDE_PLUGIN_ROOT}\" && bun install --frozen-lockfile 2>/dev/null || bun install)",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
